---
const slides = [
  {
    badge: '100% Bond-Back Guarantee',
    title: 'End of Lease &',
    highlight: 'Deep Cleaning',
    description: 'We clean every corner—kitchens, bathrooms, walls, and more. Perfect for moving out or a deep seasonal clean.',
  },
  {
    badge: 'Clean, Fresh, and Guest-Ready',
    title: 'Home &',
    highlight: 'Airbnb Cleaning',
    description: 'Regular or one-time cleaning for houses and short stays. Reliable, detailed, and flexible to your needs.',
  },
  {
    badge: 'Office Cleaning',
    title: 'Professional',
    highlight: '& Efficient',
    description: 'Keep your workplace spotless and welcoming. We clean desks, floors, kitchens, and restrooms—after hours available.',
  },
];
---

<div class="text-gray-800 space-y-8 p-6 sm:p-8 rounded-2xl relative overflow-hidden max-w-2xl mr-auto text-center">
  
   <!-- Cuadrícula decorativa -->
  <div
    class="absolute inset-0 opacity-[0.35] pointer-events-none"
    style="background-image: repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(29,158,117,0.5) 59px, rgba(29,158,117,0.5) 61px), repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(29,158,117,0.5) 59px, rgba(29,158,117,0.5) 61px);"
    aria-hidden="true">
  </div>
<div class="carousel-container relative z-10">
    
    {slides.map((slide, i) => (
      <div class={`carousel-slide ${i === 0 ? 'active' : ''}`}>
        <div class="space-y-6">
          <div class="inline-flex items-center px-4 py-2 bg-green-100 border border-green-200 rounded-full text-green-700 text-sm font-medium">
            {slide.badge}
          </div>
          <h1 class="text-white text-3xl md:text-5xl lg:text-6xl font-bold leading-tight">
            {slide.title}
            <span class="text-transparent bg-clip-text bg-gradient-to-r color-glow">{slide.highlight}</span>
          </h1>
<p class="text-lg sm:text-xl text-gray-600 leading-relaxed max-w-xl mx-auto">{slide.description}</p>
        </div>
      </div>
    ))}
  </div>

 <div class="flex space-x-3 justify-center relative z-10">
  
    {slides.map((_, i) => (
      <button
        class={`carousel-indicator ${i === 0 ? 'active bg-glow' : 'bg-gray-300 hover:bg-gray-400'} w-3 h-3 rounded-full transition-all duration-300`}
        data-slide={i}
      />
    ))}
  </div>
  <div class="flex flex-wrap justify-center gap-3 pt-6 relative z-10">

  <!-- BOTÓN PRINCIPAL (scroll al formulario) -->
  <a
    href="#quote_form"
     class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold rounded-lg bg-[#1e9b71] text-white hover:bg-[#157a57] transition-all duration-300 shadow-lg shadow-black/30 hover:scale-[1.02] active:scale-[0.98]"
>
    Get a Free Quote

    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M5 12h14M12 5l7 7-7 7"></path>
    </svg>
  </a>

  <!-- BOTÓN TELÉFONO -->
  <a
    href="tel:0291406006"
    class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold rounded-lg border border-white/20 text-white/85 hover:bg-white/10 hover:border-white/40 transition-all duration-300"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 .82h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path>
    </svg>

    0291 406 006
  </a>

</div>

  <div class="grid grid-cols-3 gap-8 pt-8 border-t border-gray-200">
    <div class="text-center">
      <div class="sm:text-3xl text-2xl font-bold color-glow">50+</div>
      <div class="text-sm text-gray-500">Happy clients</div>
    </div>
    <div class="text-center">
      <div class="sm:text-3xl text-2xl font-bold color-glow">5★</div>
      <div class="text-sm text-gray-500">Rating</div>
    </div>
    <div class="flex-col flex items-center justify-center space-x-6 relative z-10">
      <div class="sm:text-3xl text-2xl font-bold color-glow ">7 days</div>
      <div class="text-sm text-gray-500">Available</div>
    </div>
  </div>

  <div class="justify-center flex items-center space-x-6 pt-4">
    {['Insured', 'Eco-Friendly', 'Guaranteed'].map(label => (
      <div class=" flex items-center space-x-2 text-sm text-gray-600">
        <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span>{label}</span>
      </div>
    ))}
  </div>
</div>

<script>
  let current = 0;
  const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
  const indicators = document.querySelectorAll<HTMLButtonElement>('.carousel-indicator');
  const total = slides.length;

  function goTo(index: number) {
    slides.forEach(s => s.classList.remove('active'));
    indicators.forEach((ind, i) => {
      if (i === index) {
        ind.classList.add('active', 'bg-glow');
        ind.classList.remove('bg-gray-300');
      } else {
        ind.classList.remove('active', 'bg-glow');
        ind.classList.add('bg-gray-300');
      }
    });
    slides[index]?.classList.add('active');
  }

  function next() { current = (current + 1) % total; goTo(current); }
  let timer = setInterval(next, 6000);

  indicators.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      current = i; goTo(i);
      clearInterval(timer);
      timer = setInterval(next, 6000);
    });
  });

  const fields = document.querySelectorAll('#cleaningForm input, #cleaningForm select, #cleaningForm textarea');
  fields.forEach(el => {
    el.addEventListener('focus', () => clearInterval(timer));
    el.addEventListener('blur', () => { timer = setInterval(next, 6000); });
  });
</script>
