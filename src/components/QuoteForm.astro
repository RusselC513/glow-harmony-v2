---
---
<div class="text-center mb-8">
        <h2 class="text-[40px] sm:text-[52px] lg:text-[64px] font-semibold tracking-tighter leading-[0.9] text-[#1d1d1f]">
          <span class="block mb-2">
            Get Ready to
            <span class="bg-gradient-to-r from-[#1D9E75] via-[#1D9E75]/90 to-[#1D9E75]/80 bg-clip-text text-transparent inline-block">
              Start!
            </span>
          </span>
          <span class="block text-[28px] sm:text-[36px] lg:text-[42px] text-[#86868b] font-normal tracking-[-0.012em] mt-6">
            It's fast, free and very easy
          </span>
        </h2>
      </div>
<div class="bg-white/90 backdrop-blur-lg border border-gray-200 rounded-2xl p-3 sm:p-8 shadow-2xl" style="
    margin: 2rem;
" >
  <div class="text-center mb-8">
    <h2 class="text-3xl font-bold text-gray-800 mb-2">FREE QUOTE!</h2>
  </div>

  <form class="space-y-6" id="cleaningForm">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Full name *</label>
        <input type="text" id="name" name="name" required
          class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-300"
          placeholder="Your full name" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email *</label>
        <input type="email" id="email" name="email" required
          class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-300"
          placeholder="your@email.com" />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone number *</label>
        <input type="tel" id="phone" name="phone" required
          class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-300"
          placeholder="+61 000 000 000" />
      </div>
      <div>
        <label for="service" class="block text-sm font-medium text-gray-700 mb-2">Type of service *</label>
        <select id="service" name="service" required
          class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-300">
          <option value="" disabled selected>Select a service</option>
          <option value="residential">Residential Cleaning</option>
          <option value="commercial">Commercial Cleaning</option>
          <option value="deep-cleaning">Deep Cleaning</option>
          <option value="end-of-lease">End of lease</option>
          <option value="move-in-out">Move In/Out Cleaning</option>
          <option value="airbnb-cleaning">Airbnb Cleaning</option>
          <option value="other">Other</option>
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="size" class="block text-sm font-medium text-gray-700 mb-2">Property size</label>
        <select id="size" name="size"
          class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-300">
          <option value="" disabled selected>Select Size</option>
          <option value="small">Small (1-2 bedrooms)</option>
          <option value="medium">Medium (3-4 bedrooms)</option>
          <option value="large">Large (5+ bedrooms)</option>
        </select>
      </div>
      <div>
        <label for="frequency" class="block text-sm font-medium text-gray-700 mb-2">Cleaning frequency</label>
        <select id="frequency" name="frequency"
          class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-300">
          <option value="" disabled selected>How often?</option>
          <option value="one-time">One Time</option>
          <option value="weekly">Weekly</option>
          <option value="biweekly">Biweekly</option>
          <option value="monthly">Monthly</option>
          <option value="custom">Custom</option>
        </select>
      </div>
    </div>

    <div>
      <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Additional details</label>
      <textarea id="message" name="message" rows="3"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-300 resize-none"
        placeholder="Tell us about specific needs, access, pets, etc..."></textarea>
    </div>

    <button type="submit"
      class="w-full px-6 py-4 bg-glow text-white font-semibold rounded-lg transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
      REQUEST FREE QUOTE
    </button>
  </form>
</div>

<script>
  import { db } from '../lib/firebase';
  import { collection, addDoc, serverTimestamp } from 'firebase/firestore';

  const form = document.getElementById('cleaningForm') as HTMLFormElement | null;
  const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  form?.addEventListener('submit', async function (e) {
    e.preventDefault();
    const data = new FormData(this as HTMLFormElement);
    const fields = Object.fromEntries(data.entries()) as Record<string, string>;
    const { name, email, phone, service } = fields;

    if (!name || !email || !phone || !service) {
      alert('Please complete all required fields (*)');
      return;
    }

    if (btn) { btn.disabled = true; btn.textContent = 'Sending...'; }

    try {
      // Guarda en Firestore
      await addDoc(collection(db, 'quotes'), {
        name,
        email,
        phone,
        service,
        size: fields.size || '',
        frequency: fields.frequency || '',
        message: fields.message || '',
        createdAt: serverTimestamp(),
      });

      // Dispara email via Firebase Extension "Trigger Email"
      await addDoc(collection(db, 'mail'), {
        to: ['glowandharmony1@gmail.com', 'otro@correo.com'],
        message: {
          subject: `New Quote Request from ${name}`,
          html: `
            <h2>New quote request received</h2>
            <p><b>Name:</b> ${name}</p>
            <p><b>Email:</b> ${email}</p>
            <p><b>Phone:</b> ${phone}</p>
            <p><b>Service:</b> ${service}</p>
            <p><b>Property size:</b> ${fields.size || '-'}</p>
            <p><b>Frequency:</b> ${fields.frequency || '-'}</p>
            <p><b>Details:</b> ${fields.message || '-'}</p>
          `,
        },
      });

      // También envía al backend existente (opcional)
      await fetch('https://bknd-aus-production-66f4.up.railway.app/api/quote', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: data,
      }).catch(() => {}); // no bloquea si falla

      window.location.href = '/thanks';
    } catch (err) {
      console.error(err);
      alert('There was a problem sending your request.');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'REQUEST FREE QUOTE'; }
    }
  });
</script>
