---
const reviews = [
  { name: 'Daniela G', avatar: 'https://lh3.googleusercontent.com/a/ACg8ocLd-SyI64EjryILVv2DWLaSKJedR0td6QD5Kqhg_jdSDo9M6y8=s64-c-rp-mo-br100', rating: 5, text: 'Excellent cleaning service, very professional and thorough. Highly recommended!', date: 'June 15, 2025' },
  { name: 'Marie Stevenson', avatar: 'https://lh3.googleusercontent.com/a-/ALV-UjVFeDHioM3yeyjVMLzp36Gkr_JAvcza_P2KhUB7FEXd3jdT-zQ=s64-c-rp-mo-br100', rating: 4, text: 'Great overall experience. My place looked spotless after the cleaning.', date: 'May 10, 2025' },
  { name: 'Ana M', avatar: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=64&h=64&fit=crop&crop=face', rating: 5, text: 'Amazing quality and quick service. Definitely will book again!', date: 'May 8, 2025' },
  { name: 'Aarom Williams', avatar: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=64&h=64&fit=crop&crop=face', rating: 4, text: 'Good service, though the appointment started a bit later than expected.', date: 'June 5, 2025' },
  { name: 'Nicole Rowles', avatar: 'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=64&h=64&fit=crop&crop=face', rating: 5, text: 'Perfect in every way. Exceptional customer care.', date: 'May 1, 2025' },
  { name: 'Liam H', avatar: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=64&h=64&fit=crop&crop=face', rating: 5, text: 'Good service overall. The team was friendly and left everything spotless.', date: 'April 28, 2025' },
];

const starPath = 'M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z';
---

<section id="reviews" class="py-20 sm:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-yellow-50 text-yellow-700 rounded-full text-sm font-semibold mb-4 tracking-wide">
        ★ Client Reviews
      </span>
      <h2 class="font-display text-4xl sm:text-5xl font-bold text-gray-900 mb-4">What Our Clients Say</h2>
      <p class="text-lg text-gray-500 max-w-xl mx-auto">Trusted by dozens of satisfied clients across Hobart.</p>
    </div>

    <!-- Desktop grid -->
    <div class="hidden lg:grid lg:grid-cols-3 gap-6">
      {reviews.map(r => (
        <div class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg hover:border-green-100 transition-all duration-300 p-6 flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <img src={r.avatar} alt={r.name} class="w-12 h-12 rounded-full object-cover ring-2 ring-green-100" />
            <div>
              <p class="font-semibold text-gray-900 text-sm">{r.name}</p>
              <div class="flex items-center gap-0.5 mt-0.5">
                {Array.from({ length: 5 }, (_, i) => (
                  <svg class={`w-3.5 h-3.5 ${i < r.rating ? 'text-yellow-400' : 'text-gray-200'}`} fill="currentColor" viewBox="0 0 20 20">
                    <path d={starPath}/>
                  </svg>
                ))}
              </div>
            </div>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed flex-1">"{r.text}"</p>
          <p class="text-xs text-gray-400">{r.date}</p>
        </div>
      ))}
    </div>

    <!-- Mobile carousel -->
    <div class="lg:hidden">
      <div class="overflow-hidden">
        <div id="reviewsCarousel" class="flex transition-transform duration-300 ease-in-out">
          {reviews.map(r => (
            <div class="flex-shrink-0 w-full px-1">
              <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 max-w-sm mx-auto">
                <div class="flex items-center gap-3 mb-4">
                  <img src={r.avatar} alt={r.name} class="w-12 h-12 rounded-full object-cover ring-2 ring-green-100" />
                  <div>
                    <p class="font-semibold text-gray-900 text-sm">{r.name}</p>
                    <div class="flex items-center gap-0.5 mt-0.5">
                      {Array.from({ length: 5 }, (_, i) => (
                        <svg class={`w-3.5 h-3.5 ${i < r.rating ? 'text-yellow-400' : 'text-gray-200'}`} fill="currentColor" viewBox="0 0 20 20">
                          <path d={starPath}/>
                        </svg>
                      ))}
                    </div>
                  </div>
                </div>
                <p class="text-gray-600 text-sm leading-relaxed mb-3">"{r.text}"</p>
                <p class="text-xs text-gray-400">{r.date}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="flex justify-center gap-2 mt-6">
        {reviews.map((_, i) => (
          <button class="review-dot w-2 h-2 rounded-full bg-gray-300 transition-all duration-300" data-index={i}/>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const carousel = document.getElementById('reviewsCarousel');
  const dots = document.querySelectorAll<HTMLButtonElement>('.review-dot');
  let cur = 0;

  function goTo(i: number) {
    cur = i;
    if (carousel) carousel.style.transform = `translateX(-${i * 100}%)`;
    dots.forEach((d, idx) => {
      d.className = `review-dot rounded-full transition-all duration-300 ${idx === i ? 'w-4 h-2 bg-green-500' : 'w-2 h-2 bg-gray-300'}`;
    });
  }

  dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
  goTo(0);
  setInterval(() => goTo((cur + 1) % dots.length), 4000);
</script>
