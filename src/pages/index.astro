---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import QuoteForm from '../components/QuoteForm.astro';
import Services from '../components/Services.astro';
import Reviews from '../components/Reviews.astro';
import Footer from '../components/Footer.astro';
import RevealBox from "../components/RevealBox.astro";
---
<Layout>
  <Header />

  <section class="min-h-screen bg-[hsl(162,25%,10%)] flex items-center relative overflow-hidden py-4 sm:py-0">
  

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10">
      <div class="grid lg:grid-cols-2 gap-8 items-center">
          <HeroCarousel />
          <div class="w-full flex justify-center">
            <RevealBox />
          </div>
      </div>
    
    </div>
  </section>

  <section id="quote_form" class="bg-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <QuoteForm />
    </div>
  </section>

  <Services />
  <Reviews />
  <Footer />
</Layout>